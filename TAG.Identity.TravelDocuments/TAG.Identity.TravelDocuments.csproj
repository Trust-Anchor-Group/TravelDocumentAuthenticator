<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Root\TravelDocuments\TravelDocuments.md" />
    <None Remove="TAG.Identity.TravelDocuments.manifest" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Root\TravelDocuments\TravelDocuments.md">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="TAG.Identity.TravelDocuments.manifest">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Paiwise" Version="3.1.0" />
    <PackageReference Include="Waher.Content" Version="3.4.7" />
    <PackageReference Include="Waher.Events" Version="1.4.7" />
    <PackageReference Include="Waher.IoTGateway" Version="3.6.0" />
