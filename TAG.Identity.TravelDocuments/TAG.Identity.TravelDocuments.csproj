    <PackageReference Include="Waher.Runtime.Inventory" Version="1.4.6" />
    <PackageReference Include="Waher.Runtime.Settings" Version="1.2.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\NeuroAccessMaui\NeuroAccess.Nfc\NeuroAccess.Nfc.csproj" />
  </ItemGroup>

  <Target Name="PostBuild" AfterTargets="PostBuildEvent">
    <Exec Command="&quot;C:\My Projects\IoTGateway\Utilities\Waher.Utility.Install\bin\$(ConfigurationName)\net8.0\win-x86\Waher.Utility.Install.exe&quot; -m &quot;C:\My Projects\TravelDocumentAuthenticator\TAG.Identity.TravelDocuments\bin\$(ConfigurationName)\netstandard2.1\TAG.Identity.TravelDocuments.manifest&quot; -s &quot;C:\My Projects\IoTGateway\Waher.IoTGateway.Console\bin\$(ConfigurationName)\net8.0\Waher.IoTGateway.Console.dll&quot; -d &quot;C:\ProgramData\IoT Gateway Dev&quot;&#xD;&#xA;" />
  </Target>

</Project>
